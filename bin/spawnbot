#!/usr/bin/env bash
#
# spawnbot — friendly CLI wrapper
#
# One command: `spawnbot` starts the daemon (if needed) and opens the TUI.
# Installed to ~/.spawnbot/bin/spawnbot and added to PATH.
#

set -euo pipefail

# Resolve the spawnbot installation directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPAWNBOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# State files for daemon management
STATE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/spawnbot"
PID_FILE="$STATE_DIR/daemon.pid"
PORT_FILE="$STATE_DIR/daemon.port"
LOG_DIR="$STATE_DIR/log"

# Resolve the agent's workspace directory.
# Priority: SPAWNBOT_WORKSPACE env var > workspace/.env > default (SPAWNBOT_DIR/workspace)
resolve_workspace() {
  if [[ -n "${SPAWNBOT_WORKSPACE:-}" ]]; then
    echo "$SPAWNBOT_WORKSPACE"
    return
  fi
  # Try to read from workspace/.env
  local env_file="$SPAWNBOT_DIR/workspace/.env"
  if [[ -f "$env_file" ]]; then
    local ws
    ws=$(grep -m1 '^SPAWNBOT_WORKSPACE=' "$env_file" 2>/dev/null | cut -d= -f2- | xargs)
    if [[ -n "$ws" ]]; then
      echo "$ws"
      return
    fi
  fi
  echo "$SPAWNBOT_DIR/workspace"
}

WORKSPACE="$(resolve_workspace)"

# Ensure bun is available (may need to source ~/.bun if just installed)
check_bun() {
  if ! command -v bun &>/dev/null; then
    if [[ -f "$HOME/.bun/bin/bun" ]]; then
      export BUN_INSTALL="$HOME/.bun"
      export PATH="$BUN_INSTALL/bin:$PATH"
    else
      echo "Error: bun is not installed."
      echo "Install it with: curl -fsSL https://bun.sh/install | bash"
      exit 1
    fi
  fi
}

# Run the TypeScript CLI via bun
# Must cd to SPAWNBOT_DIR so bun finds bunfig.toml (needed for JSX preload).
# Preserve original PWD so the TUI knows the real project directory.
run_cli() {
  check_bun
  export SPAWNBOT_ORIGINAL_CWD="${SPAWNBOT_ORIGINAL_CWD:-$PWD}"
  cd "$SPAWNBOT_DIR"
  exec bun run --conditions=browser "$SPAWNBOT_DIR/src/index.ts" "$@"
}

# Check if daemon is running. Sets DAEMON_PID and DAEMON_PORT on success.
daemon_running() {
  DAEMON_PID=""
  DAEMON_PORT=""
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid=$(cat "$PID_FILE" 2>/dev/null)
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      DAEMON_PID="$pid"
      # Read port from daemon's port file
      if [[ -f "$PORT_FILE" ]]; then
        DAEMON_PORT=$(cat "$PORT_FILE" 2>/dev/null)
      fi
      # If no port file yet, try default
      if [[ -z "$DAEMON_PORT" ]]; then
        DAEMON_PORT="4096"
      fi
      return 0
    fi
  fi
  # Clean up stale files
  rm -f "$PID_FILE" "$PORT_FILE"
  return 1
}

# Check if port 4096 is already in use by an orphan daemon (no PID file).
# If found, adopt it by writing PID/port files. Returns 0 if adopted.
adopt_orphan_daemon() {
  local orphan_pid
  orphan_pid=$(ss -tlnp 2>/dev/null | grep ":4096 " | grep -oP 'pid=\K[0-9]+' | head -1)
  if [[ -n "$orphan_pid" ]] && kill -0 "$orphan_pid" 2>/dev/null; then
    # Verify it's actually a spawnbot process
    local cmdline
    cmdline=$(cat /proc/"$orphan_pid"/cmdline 2>/dev/null | tr '\0' ' ')
    if [[ "$cmdline" == *spawnbot* ]] || [[ "$cmdline" == *"src/index.ts"* ]]; then
      echo "Found orphan spawnbot daemon (PID $orphan_pid) on port 4096 — adopting it."
      mkdir -p "$STATE_DIR"
      echo "$orphan_pid" > "$PID_FILE"
      echo "4096" > "$PORT_FILE"
      DAEMON_PID="$orphan_pid"
      DAEMON_PORT="4096"
      return 0
    fi
  fi
  return 1
}

# Start the daemon in background. Sets DAEMON_PID and DAEMON_PORT.
start_daemon() {
  check_bun
  mkdir -p "$STATE_DIR" "$LOG_DIR"

  # Check for orphan daemon on our port first
  if adopt_orphan_daemon; then
    return 0
  fi

  # Start daemon in background, redirect output to log
  # Ensure workspace directory exists
  mkdir -p "$WORKSPACE"

  export SPAWNBOT_ORIGINAL_CWD="${PWD}"
  cd "$SPAWNBOT_DIR"
  nohup bun run --conditions=browser "$SPAWNBOT_DIR/src/index.ts" daemon \
    --port 4096 \
    --directory "$WORKSPACE" \
    >> "$LOG_DIR/daemon.log" 2>&1 &
  local daemon_pid=$!

  echo "$daemon_pid" > "$PID_FILE"

  # Wait for daemon to write its port file (up to 90s — ngrok retry can take up to 60s)
  local waited=0
  while [[ $waited -lt 90 ]]; do
    if ! kill -0 "$daemon_pid" 2>/dev/null; then
      echo "Daemon process died during startup. Check logs:" >&2
      tail -5 "$LOG_DIR/daemon.log" 2>/dev/null >&2
      rm -f "$PID_FILE" "$PORT_FILE"
      return 1
    fi
    # Check if daemon has written its port file
    if [[ -f "$PORT_FILE" ]]; then
      DAEMON_PID="$daemon_pid"
      DAEMON_PORT=$(cat "$PORT_FILE" 2>/dev/null)
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done

  echo "Daemon startup timed out (90s). Check logs:" >&2
  tail -5 "$LOG_DIR/daemon.log" 2>/dev/null >&2
  rm -f "$PID_FILE" "$PORT_FILE"
  return 1
}

# Ensure daemon is running. Starts it if needed.
# Returns 0 on success, 1 if daemon couldn't start.
ensure_daemon() {
  if daemon_running; then
    return 0
  fi
  echo "Starting spawnbot daemon..."
  if start_daemon; then
    echo "Daemon started (PID $DAEMON_PID, port $DAEMON_PORT)"
    return 0
  fi
  return 1
}

# Attach TUI to the running daemon
attach_tui() {
  local extra_args=("$@")
  check_bun
  export SPAWNBOT_ORIGINAL_CWD="${PWD}"
  cd "$SPAWNBOT_DIR"
  exec bun run --conditions=browser "$SPAWNBOT_DIR/src/index.ts" \
    attach "http://127.0.0.1:${DAEMON_PORT}" --continue --dir "$WORKSPACE" "${extra_args[@]}"
}

# --- Commands ---

cmd_stop() {
  if ! daemon_running; then
    # Check for orphan daemon without PID file
    if adopt_orphan_daemon; then
      echo "Found orphan daemon (PID $DAEMON_PID)."
    else
      echo "spawnbot is not running."
      return 0
    fi
  fi

  echo "Stopping spawnbot (PID $DAEMON_PID)..."
  kill "$DAEMON_PID" 2>/dev/null || true

  # Wait for graceful shutdown (up to 10s)
  local waited=0
  while kill -0 "$DAEMON_PID" 2>/dev/null && [[ $waited -lt 10 ]]; do
    sleep 1
    waited=$((waited + 1))
  done

  if kill -0 "$DAEMON_PID" 2>/dev/null; then
    echo "Force killing..."
    kill -9 "$DAEMON_PID" 2>/dev/null || true
  fi

  rm -f "$PID_FILE" "$PORT_FILE"
  echo "spawnbot stopped."
}

cmd_restart() {
  cmd_stop
  ensure_daemon
  echo "spawnbot restarted."
}

cmd_status() {
  if daemon_running; then
    echo "spawnbot is running (PID $DAEMON_PID, port $DAEMON_PORT)"
  else
    echo "spawnbot is not running."
  fi
}

cmd_logs() {
  local log_file="$LOG_DIR/daemon.log"
  if [[ ! -f "$log_file" ]]; then
    echo "No log file found at $log_file"
    exit 1
  fi

  local lines="${1:-50}"
  if [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]]; then
    tail -f "$log_file"
  else
    tail -n "$lines" "$log_file"
    echo ""
    echo "Tip: use 'spawnbot logs -f' to follow logs in real time."
  fi
}

cmd_nuke() {
  echo ""
  echo "This will PERMANENTLY DELETE:"
  echo "  ~/.spawnbot/                          (source + workspace)"
  echo "  ~/.local/share/spawnbot/              (database, sessions, logs)"
  echo "  ~/.config/spawnbot/                   (auth, API keys)"
  echo "  ~/.cache/spawnbot/                    (LLM cache)"
  echo "  ~/.local/state/spawnbot/              (state)"
  echo ""
  echo "Your SOUL.md, memories, conversation history, and API keys will be GONE."
  echo ""
  read -p "Type 'nuke' to confirm: " -r
  if [[ "$REPLY" != "nuke" ]]; then
    echo "Aborted."
    return 0
  fi

  # Stop daemon first
  if daemon_running; then
    cmd_stop
  fi

  rm -rf "$HOME/.spawnbot"
  rm -rf "${XDG_DATA_HOME:-$HOME/.local/share}/spawnbot"
  rm -rf "${XDG_CONFIG_HOME:-$HOME/.config}/spawnbot"
  rm -rf "${XDG_CACHE_HOME:-$HOME/.cache}/spawnbot"
  rm -rf "${XDG_STATE_HOME:-$HOME/.local/state}/spawnbot"

  echo ""
  echo "All spawnbot data removed."
  echo "To reinstall: curl -fsSL https://raw.githubusercontent.com/dawnforge-lab/spawnbot/main/install.sh | bash"
  echo ""
  echo "Note: remove the PATH entry from your shell config (~/.bashrc, ~/.zshrc):"
  echo "  export PATH=\"\$HOME/.spawnbot/bin:\$PATH\""
}

cmd_help() {
  echo "spawnbot — autonomous AI agent"
  echo ""
  echo "Usage: spawnbot [command] [options]"
  echo ""
  echo "Commands:"
  echo "  (default)    Start daemon + open TUI (one command does everything)"
  echo "  setup        Start daemon + open TUI with /setup wizard"
  echo "  stop         Stop the background daemon"
  echo "  restart      Restart the daemon"
  echo "  status       Check if the daemon is running"
  echo "  logs [N|-f]  Show last N log lines (default: 50) or follow with -f"
  echo "  doctor       Check configuration and dependencies"
  echo "  config       Configure API keys, Telegram, ngrok, OpenAI"
  echo "  run \"msg\"    Send a one-shot message and get a response"
  echo "  reset        Clear conversation history (fresh start)"
  echo "  nuke         Stop daemon + delete ALL data (full clean reset)"
  echo ""
  echo "Advanced:"
  echo "  daemon       Start daemon in foreground (for debugging)"
  echo "  auth         Manage LLM provider credentials"
  echo "  models       List available models"
  echo "  session      Manage sessions"
  echo "  --help       Show all commands"
  echo ""
  echo "Get started:  spawnbot"
  echo "Type /help in the TUI for keyboard shortcuts and commands."
}

# --- Main ---

case "${1:-}" in
  stop)
    cmd_stop
    ;;
  restart)
    shift
    cmd_restart
    ;;
  status)
    cmd_status
    ;;
  logs)
    shift
    cmd_logs "${1:-50}"
    ;;
  reset)
    run_cli reset-session
    ;;
  nuke)
    cmd_nuke
    ;;
  help|-h|--help)
    cmd_help
    ;;
  start)
    # Start daemon only (no TUI)
    shift
    if daemon_running; then
      echo "spawnbot is already running (PID $DAEMON_PID, port $DAEMON_PORT)"
      exit 0
    fi
    echo "Starting spawnbot daemon..."
    start_daemon
    echo "Daemon started (PID $DAEMON_PID, port $DAEMON_PORT)"
    echo "Logs: $LOG_DIR/daemon.log"
    echo ""
    echo "Run 'spawnbot' to open the TUI."
    ;;
  setup)
    # Start daemon + open TUI with /setup
    # If daemon can't start, fall back to standalone TUI with /setup prompt
    shift
    if ensure_daemon; then
      check_bun
      export SPAWNBOT_ORIGINAL_CWD="${PWD}"
      cd "$SPAWNBOT_DIR"
      exec bun run --conditions=browser "$SPAWNBOT_DIR/src/index.ts" \
        attach "http://127.0.0.1:${DAEMON_PORT}" --continue --dir "$WORKSPACE" --prompt "/setup"
    else
      echo ""
      echo "Daemon could not start. Run 'spawnbot config' to set up credentials,"
      echo "or check 'spawnbot logs' for details."
    fi
    ;;
  daemon|doctor|auth|models|session|run|serve|upgrade|debug|agent|github|config)
    # Pass through to TypeScript CLI
    run_cli "$@"
    ;;
  *)
    # Default: ensure daemon + open TUI attached to it
    # If daemon can't start (no API key yet), fall back to standalone TUI
    if ensure_daemon; then
      attach_tui "$@"
    else
      echo ""
      echo "Daemon could not start."
      echo ""
      echo "Troubleshooting:"
      echo "  1. Check logs:    spawnbot logs"
      echo "  2. Run config:    spawnbot config"
      echo "  3. Run doctor:    spawnbot doctor"
      echo "  4. Try manually:  spawnbot daemon --port 4096 --directory \"$WORKSPACE\" --print-logs"
    fi
    ;;
esac
