{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {}
    },
    "railway": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "ide-assistant", "--project", "."],
      "env": {}
    },
    "linear-server": {
      "type": "sse",
      "url": "https://mcp.linear.app/sse"
    },
    "semgrep": {
      "type": "stdio",
      "command": "uvx",
      "args": ["semgrep-mcp"],
      "env": {}
    },
    "stripe": {
      "type": "http",
      "url": "https://mcp.stripe.com"
    },
    "vibe-check": {
      "type": "stdio",
      "command": "node",
      "args": ["/home/eugen-dev/vibe-check-mcp-server/build/index.js"],
      "envFile": "/home/eugen-dev/vibe-check-mcp-server/.env",
      "env": {
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}